# ─── Server ───────────────────────────────────────
PORT=9000
ENVIRONMENT=development    # development | staging | production
BASE_URL=http://localhost:9000

# ─── Database ─────────────────────────────────────
DATABASE_URL=postgres://keygate:keygate@localhost:5432/keygate?sslmode=disable

# ─── Security (required, generate with: openssl rand -hex 32) ───
JWT_SECRET=
LICENSE_SIGNING_KEY=

# ─── Payments (Stripe) ──────────────────────────
# Stripe: https://dashboard.stripe.com/apikeys
# Only STRIPE_SECRET_KEY is required. Webhook is auto-configured.
STRIPE_SECRET_KEY=

# ─── Email (optional, OTP codes print to logs if not set) ───
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# ─── Redis (optional, for distributed rate limiting) ───
REDIS_URL=

# ─── Rate Limits (requests per minute) ───────────
RATE_LIMIT_API=60
RATE_LIMIT_ADMIN=120

# ─── Webhooks ────────────────────────────────────
WEBHOOK_MAX_ATTEMPTS=5
WEBHOOK_RETRY_INTERVAL=30s
WEBHOOK_HTTP_TIMEOUT=10s

# ─── Quotas ──────────────────────────────────────
QUOTA_WARNING_THRESHOLD=0.8

# ─── Admin Bootstrap ─────────────────────────────
# Comma-separated emails to auto-promote to admin on first login.
ADMIN_EMAILS=
